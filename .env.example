# Copy to .env and fill from https://dashboard.alchemy.com/
ALCHEMY_API_KEY=
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
SOLANA_MAINNET_RPC_URL=https://solana-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
CYFRIN_API_KEY=

# v5 production cron (sourced by hermes/scripts/nss-hipif-chain.sh)
NSS_HIPIF_PAUSE_FOR_NATIVE=0
NSS_PHASE4_ROTATION_ENABLED=1
NSS_HIPIF_MODE=deterministic
NSS_HIPIF_BOUNTY_DEPTH=1
NSS_KLEND_FIXTURE=0
HERMES_CRON_SCRIPT_TIMEOUT=10800
NSS_PREFER_SOLANA=1
NSS_DISCOVERY_MISSING_PCT=0.8
