{
  "name": "nss-x402-proxy",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Local JSON-RPC proxy to QuickNode x402 Solana mainnet for NSS validator replay",
  "scripts": {
    "start": "node server.mjs",
    "health": "node -e \"fetch(process.env.X402_PROXY_URL||'http://127.0.0.1:18989',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({jsonrpc:'2.0',id:1,method:'getHealth',params:[]})}).then(r=>r.json()).then(console.log).catch(e=>{console.error(e);process.exit(1)})\""
  },
  "dependencies": {
    "@quicknode/x402": "^0.1.3",
    "@solana/signers": "^2.1.0"
  }
}