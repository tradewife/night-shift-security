{
  "version": "0.1.0",
  "templates": [
    "governance_capture",
    "treasury_drain",
    "flash_loan_oracle",
    "reentrancy",
    "composability_risk",
    "upgradeability_risk",
    "access_control_escalation"
  ],
  "hypothesis_generation": {
    "enabled": true,
    "grid_enabled": true,
    "samples_per_template": 20,
    "sample_fraction_of_grid": null,
    "structural_validation": true,
    "structural_filters": {
      "enabled": true,
      "dedupe": true,
      "feasibility_checks": true,
      "min_priority_score": 0.05
    }
  },
  "findings_store": {
    "enabled": true,
    "path": "data/security_results/knowledge/findings_store.jsonl"
  },
  "validation_layer": {
    "impact_ceiling_usd": 100000000,
    "level_1_mc_min": 0.7,
    "max_pbo": 0.3
  },
  "llm_expansion": {
    "enabled": false,
    "fallback": "parametric",
    "variants_per_seed": 2,
    "max_seeds": 5,
    "provider": "litellm",
    "model": "xai/grok-4",
    "api_key_env": "XAI_API_KEY",
    "auth_source": "auto",
    "temperature": 0.7,
    "max_tokens": 1024,
    "timeout_seconds": 30,
    "api_base": "https://api.x.ai/v1"
  },
  "darwinian": {
    "enabled": true,
    "generations": 3,
    "population": 10,
    "perturbation_range": [
      0.05,
      0.15
    ],
    "offspring_per_parent": 3
  },
  "gates": {
    "min_reproducibility": 0.8,
    "min_severity_score": 0.5,
    "min_economic_impact_usd": 100000,
    "min_invariant_violations": 1,
    "min_realism_score": 0.4,
    "min_generality": 0.15,
    "max_capital_required_usd": 50000000
  },
  "monte_carlo": {
    "enabled": true,
    "top_n": 10,
    "n_simulations": 100,
    "perturbation_range": [
      0.05,
      0.2
    ],
    "min_reproducibility": 0.7
  },
  "foundry": {
    "enabled": true,
    "top_n": 5,
    "fork_url": ""
  },
  "cpcv": {
    "enabled": true,
    "top_n": 5,
    "n_variants": 15,
    "n_test_folds": 2,
    "max_pbo": 0.3
  },
  "fork_validation": {
    "enabled": true,
    "top_n": 3,
    "always_test_catalog_evm_anchors": true,
    "score_multiplier": 1.2,
    "targets": [
      "euler-finance-2023",
      "nomad-bridge-2022",
      "mango-markets-2022"
    ]
  },
  "solana_validation": {
    "enabled": true,
    "top_n": 3,
    "always_test_catalog_solana_anchors": true,
    "score_multiplier": 1.1
  },
  "output_dir": "data/security_results",
  "rediscovery": {
    "enabled": true,
    "parameter_tolerance": 5.0
  },
  "monitoring": {
    "enabled": true,
    "min_severity": "high",
    "webhook_url": "",
    "alert_file": "data/security_results/alerts.jsonl"
  },
  "bounty": {
    "enabled": true,
    "min_severity": "high",
    "immunefi_packs": true,
    "min_evidence_grade": 3
  },
  "target": {
    "enabled": false
  },
  "operator": {
    "task_verifier": {
      "enabled": true,
      "threshold_wei": "100000000000000000",
      "required_for_novel": true,
      "attacker_env": "OPERATOR_ATTACKER"
    },
    "checkpoint": {
      "enabled": true,
      "path": "data/security_results/operator/checkpoint.json"
    },
    "trials": {
      "default_n": 1,
      "high_priority_n": 30,
      "high_priority_min_bounty_usd": 500000
    }
  }
}