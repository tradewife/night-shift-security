{
  "version": "0.1.0",
  "templates": [
    "governance_capture",
    "treasury_drain",
    "flash_loan_oracle",
    "reentrancy"
  ],
  "darwinian": {
    "enabled": true,
    "generations": 3,
    "population": 10,
    "perturbation_range": [0.05, 0.15],
    "offspring_per_parent": 3
  },
  "gates": {
    "min_reproducibility": 0.80,
    "min_severity_score": 0.50,
    "min_economic_impact_usd": 100000,
    "min_invariant_violations": 1,
    "min_realism_score": 0.40,
    "min_generality": 0.15,
    "max_capital_required_usd": 50000000
  },
  "monte_carlo": {
    "enabled": true,
    "top_n": 10,
    "n_simulations": 100,
    "perturbation_range": [0.05, 0.20],
    "min_reproducibility": 0.70
  },
  "foundry": {
    "enabled": true,
    "top_n": 5,
    "fork_url": ""
  },
  "cpcv": {
    "enabled": true,
    "top_n": 5,
    "n_variants": 15,
    "n_test_folds": 2,
    "max_pbo": 0.30
  },
  "fork_validation": {
    "enabled": true,
    "top_n": 3,
    "targets": ["euler-finance-2023", "mango-markets-2022"]
  },
  "output_dir": "data/security_results",
  "rediscovery": {
    "enabled": true,
    "parameter_tolerance": 5.0
  }
}