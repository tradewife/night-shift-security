{
  "version": "0.1.0",
  "templates": [
    "governance_capture",
    "treasury_drain",
    "flash_loan_oracle",
    "reentrancy",
    "composability_risk",
    "upgradeability_risk",
    "access_control_escalation"
  ],
  "hypothesis_generation": {
    "enabled": true,
    "grid_enabled": true,
    "samples_per_template": 20,
    "sample_fraction_of_grid": null,
    "structural_validation": true,
    "structural_filters": {
      "enabled": true,
      "dedupe": true,
      "feasibility_checks": true,
      "min_priority_score": 0.05
    }
  },
  "findings_store": {
    "enabled": true,
    "path": "data/security_results/knowledge/findings_store.jsonl"
  },
  "validation_layer": {
    "impact_ceiling_usd": 100000000,
    "level_1_mc_min": 0.70,
    "max_pbo": 0.30
  },
  "llm_expansion": {
    "enabled": false,
    "fallback": "parametric",
    "variants_per_seed": 2,
    "max_seeds": 5,
    "provider": "litellm",
    "model": "gpt-4o-mini",
    "api_key_env": "OPENAI_API_KEY",
    "temperature": 0.7,
    "max_tokens": 1024,
    "timeout_seconds": 30
  },
  "darwinian": {
    "enabled": true,
    "generations": 3,
    "population": 10,
    "perturbation_range": [0.05, 0.15],
    "offspring_per_parent": 3
  },
  "gates": {
    "min_reproducibility": 0.80,
    "min_severity_score": 0.50,
    "min_economic_impact_usd": 100000,
    "min_invariant_violations": 1,
    "min_realism_score": 0.40,
    "min_generality": 0.15,
    "max_capital_required_usd": 50000000
  },
  "monte_carlo": {
    "enabled": true,
    "top_n": 10,
    "n_simulations": 100,
    "perturbation_range": [0.05, 0.20],
    "min_reproducibility": 0.70
  },
  "foundry": {
    "enabled": true,
    "top_n": 5,
    "fork_url": ""
  },
  "cpcv": {
    "enabled": true,
    "top_n": 5,
    "n_variants": 15,
    "n_test_folds": 2,
    "max_pbo": 0.30
  },
  "fork_validation": {
    "enabled": true,
    "top_n": 3,
    "always_test_catalog_evm_anchors": true,
    "score_multiplier": 1.20,
    "targets": ["euler-finance-2023", "nomad-bridge-2022", "mango-markets-2022"]
  },
  "solana_validation": {
    "enabled": true,
    "top_n": 3,
    "always_test_catalog_solana_anchors": true,
    "score_multiplier": 1.10
  },
  "output_dir": "data/security_results",
  "rediscovery": {
    "enabled": true,
    "parameter_tolerance": 5.0
  },
  "monitoring": {
    "enabled": true,
    "min_severity": "high",
    "webhook_url": "",
    "alert_file": "data/security_results/alerts.jsonl"
  },
  "bounty": {
    "enabled": true,
    "min_severity": "high"
  }
}