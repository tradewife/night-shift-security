{
  "version": "0.1.0",
  "campaign": {
    "id": "wormhole-fork-2026-06",
    "name": "Wormhole Nomad-analogue EVM fork probe"
  },
  "templates": ["access_control_escalation", "composability_risk"],
  "hypothesis_generation": {
    "enabled": true,
    "grid_enabled": true,
    "samples_per_template": 6,
    "structural_validation": true,
    "structural_filters": {
      "enabled": true,
      "dedupe": true,
      "feasibility_checks": true,
      "min_priority_score": 0.05
    }
  },
  "findings_store": {
    "enabled": true,
    "path": "data/security_results/knowledge/findings_store.jsonl"
  },
  "validation_layer": {
    "impact_ceiling_usd": 100000000,
    "level_1_mc_min": 0.7,
    "max_pbo": 0.3
  },
  "llm_expansion": {
    "enabled": false,
    "fallback": "parametric"
  },
  "darwinian": {
    "enabled": true,
    "generations": 1,
    "population": 4,
    "perturbation_range": [0.05, 0.15],
    "offspring_per_parent": 1
  },
  "gates": {
    "min_reproducibility": 0.8,
    "min_severity_score": 0.5,
    "min_economic_impact_usd": 100000,
    "min_invariant_violations": 1,
    "min_realism_score": 0.4,
    "min_generality": 0.15,
    "max_capital_required_usd": 50000000
  },
  "monte_carlo": {
    "enabled": true,
    "top_n": 3,
    "n_simulations": 30,
    "perturbation_range": [0.05, 0.2],
    "min_reproducibility": 0.7
  },
  "foundry": {
    "enabled": false,
    "top_n": 0,
    "fork_url": ""
  },
  "cpcv": {
    "enabled": true,
    "top_n": 2,
    "n_variants": 8,
    "n_test_folds": 2,
    "max_pbo": 0.3
  },
  "fork_validation": {
    "enabled": true,
    "top_n": 3,
    "always_test_catalog_evm_anchors": true,
    "score_multiplier": 1.2,
    "targets": ["nomad-bridge-2022"]
  },
  "solana_validation": {
    "enabled": false,
    "top_n": 0,
    "always_test_catalog_solana_anchors": false,
    "score_multiplier": 1.0
  },
  "output_dir": "data/security_results",
  "rediscovery": {
    "enabled": true,
    "parameter_tolerance": 5.0
  },
  "monitoring": {
    "enabled": false
  },
  "bounty": {
    "enabled": true,
    "min_severity": "high",
    "immunefi_packs": true,
    "min_evidence_grade": 3,
    "shoestring_pack": true
  },
  "target": {
    "enabled": true,
    "config_path": "targets/wormhole.json"
  }
}