model:
  default: grok-4.3
  provider: xai-oauth
  base_url: https://api.x.ai/v1
fallback_providers: []
toolsets:
  - terminal
  - file
  - search
agent:
  max_turns: 120
  gateway_timeout: 10800
  reasoning_effort: high
  verbose: false
cron:
  wrap_response: false
  script_timeout_seconds: 10800
approvals:
  cron_mode: approve
delegation:
  subagent_auto_approve: true
hooks_auto_accept: true
terminal:
  backend: local